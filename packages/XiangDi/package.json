{
  "name": "xiangdi",
  "version": "0.1.0",
  "description": "相地 —— 造园之始，先察山川形势。Banyuan 的 AI Agent 引擎，集成 SDD（Spec-Driven Development）两层规范体系与 Harness Engineering，实现可审查、可中断、可回滚的 AI 驱动应用生成。",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "banvas",
    "xiangdi",
    "llm",
    "sdd",
    "spec-driven-development",
    "harness",
    "human-in-the-loop",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "~5.7.3"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "banvasgl": "workspace:*"
  },
  "peerDependenciesMeta": {
    "banvasgl": {
      "optional": true
    }
  }
}
