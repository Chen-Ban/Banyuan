{
  "name": "@banyuan/xiangdi-agent",
  "version": "0.1.0",
  "description": "相地 —— 造园之始，先察山川形势。Banyuan 的 AI Agent 引擎，集成 SDD（Spec-Driven Development）两层规范体系与 Harness Engineering，实现可审查、可中断、可回滚的 AI 驱动应用生成。",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "prepublishOnly": "npm run build",
    "validate-seeds": "tsx scripts/generate-composition-seeds.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "banvas",
    "xiangdi",
    "llm",
    "sdd",
    "spec-driven-development",
    "harness",
    "human-in-the-loop",
    "react"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "~5.7.3"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@langchain/core": "^0.3.26",
    "@langchain/langgraph": "^0.2.36",
    "@lancedb/lancedb": "^0.27.2",
    "graphology": "^0.26.0",
    "graphology-traversal": "^0.3.1",
    "openai": "^4.98.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@banyuan/banvasgl": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@banyuan/banvasgl": {
      "optional": true
    }
  }
}
