{
  "name": "@banyuan/banvasgl",
  "version": "0.1.0",
  "description": "Banyuan 自研 2D 图形引擎，提供图形基元、场景管理、动画系统、序列化及编辑态/运行态 React Hook",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "postbuild": "tsx scripts/generate-knowledge.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "banvas",
    "canvas",
    "graph"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0"
  },
  "dependencies": {
    "@banyuan/flow": "workspace:*",
    "uuid": "^11.1.0"
  }
}
