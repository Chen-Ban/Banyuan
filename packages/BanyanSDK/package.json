{
  "name": "@banyuan/sdk",
  "version": "0.1.0",
  "description": "Banyan 低代码平台统一 SDK 入口（伞包），聚合 BanvasGL 核心引擎及运行态/编辑态/流程图编辑器",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.mts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.cjs"
    },
    "./design": {
      "types": "./dist/design.d.mts",
      "import": "./dist/design.mjs",
      "require": "./dist/design.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs",
      "require": "./dist/runtime.cjs"
    },
    "./flow": {
      "types": "./dist/flow.d.mts",
      "import": "./dist/flow.mjs",
      "require": "./dist/flow.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch"
  },
  "keywords": [
    "banyan",
    "banvas",
    "sdk",
    "low-code"
  ],
  "license": "AGPL-3.0",
  "dependencies": {
    "@banyuan/canvas": "workspace:*",
    "@banyuan/canvas-runtime": "workspace:*",
    "@banyuan/canvas-design": "workspace:*",
    "@banyuan/flow-design": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "tsup": "^8.4.0",
    "typescript": "~5.7.3"
  }
}
