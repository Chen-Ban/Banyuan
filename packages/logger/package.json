{
  "name": "@banyuan/logger",
  "version": "0.1.0",
  "description": "Banyuan 共享结构化日志库（基于 pino），统一 banyan-backend 和 xiangdi-server 的日志格式",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --treeshake",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "pnpm exec eslint . --max-warnings 1000",
    "lint:fix": "pnpm exec eslint . --fix"
  },
  "dependencies": {
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "~5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
