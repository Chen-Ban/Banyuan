    "@banyuan/canvas": "workspace:*",
    "@banyuan/canvas-runtime": "workspace:*",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@banyuan/canvas": "workspace:*",
    "@banyuan/canvas-runtime": "workspace:*",
    "react": "^19.1.0",
    "tsup": "^8.4.0"
  }
