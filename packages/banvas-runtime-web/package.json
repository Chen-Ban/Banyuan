{
  "name": "@banyuan/banvas-runtime-web",
  "version": "0.1.0",
  "description": "BanvasGL 运行态 Web 平台适配（React Hook + Canvas 2D）",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch"
  },
  "keywords": [
    "banvas",
    "runtime",
    "web",
    "react",
    "canvas"
  ],
  "license": "AGPL-3.0",
  "peerDependencies": {
    "react": "^19.1.0",
    "@banyuan/banvasgl": "workspace:*",
    "@banyuan/banvas-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@banyuan/banvasgl": "workspace:*",
    "@banyuan/banvas-runtime": "workspace:*",
    "react": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "~5.7.3"
  }
}
