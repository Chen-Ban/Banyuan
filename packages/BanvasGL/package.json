{
  "name": "banvasgl",
  "version": "0.1.0",
  "description": "一个二维图形绘制库",
  "exports": {
    ".": {
      "types": {
        "node": "./dist/index.backend.d.ts",
        "default": "./dist/index.frontend.d.ts"
      },
      "require": {
        "node": "./dist/index.backend.cjs",
        "default": "./dist/index.frontend.cjs"
      },
      "import": {
        "node": "./dist/index.backend.mjs",
        "default": "./dist/index.frontend.mjs"
      }
    },
    "./runtime": {
      "types": "./dist/index.runtime.d.ts",
      "require": "./dist/index.runtime.cjs",
      "import": "./dist/index.runtime.mjs"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "banvas",
    "canvas",
    "graph"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.4.0"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "dependencies": {
    "uuid": "^11.1.0"
  }
}
